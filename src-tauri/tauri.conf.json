{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADM",
  "version": "0.4.2",
  "identifier": "com.adm.admapp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ADM",
        "width": 1440,
        "height": 800,
        "center": true,
        "minWidth": 1440,
        "minHeight": 800,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    }
  }
}
